<h2><strong><%= @art.name %></strong> (<%= @art.abbrev %>)</h2>

<h3 id="courses">Courses (<%= @art.courses.count %>)
<%= link_to 'Add', new_art_course_path(@art), title: "Add New course to art" %></h3>
<% if @art.courses.present? %>
  <ul>
    <% @art.courses.each do |course| %>
      <li><%= link_to course, [@art, course] %></li>
    <% end %>
  </ul>
<% end %>

<h3 id="belts">Belts (<%= @art.belts.count %>)
<%= link_to 'Add', new_art_belt_path(@art), title: "Add New belt to art" %></h3>
<% if @art.belts.present? %>
  <div class="table-responsive">
    <table class="table table-striped">
      <%= render "belts/belt_header" %>
      <tbody>
        <%= render @art.belts %>
      </tbody>
    </table>
  </div>
<% end %>
