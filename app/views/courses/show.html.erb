<h2><%= @course %></h2>

<h3>Meetings (<%= @course.meetings.count %>) <%= link_to "Add", new_art_course_meeting_path(@art, @course) %></h3>
<ul>
  <% @course&.meetings.each do |meeting| %>
    <li><%= link_to meeting.date, [@art, @course, meeting] %></li>
  <% end %>
</ul>

<div>
  <%= link_to "Edit this course", edit_art_course_path(@art, @course) %> |
  <%= link_to "Back to art", @art %>

  <%= button_to "Destroy this course", [@art, @course],
      method: :delete,
      data: { turbo_confirm: "Are you sure?" } %>
</div>
