<h2><%= @course.day %> <%= @course.time.strftime("%I:%M %p") %></h2>

<h3>Meetings (<%= @course.meetings.count %>)</h3>
<% if @course.meetings.present? %>
  <ul>
    <%= render @course.meetings, course: @course %>
  </ul>
<% end %>


<div>
  <%= link_to "Edit this course", edit_art_course_path([@art, @course]) %> |
  <%= link_to "Back to art", @art %>

  <%= button_to "Destroy this course", [@art, @course],
      method: :delete,
      data: { turbo_confirm: "Are you sure?" } %> %>
</div>
